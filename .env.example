# EnergyCity — konfiguracja Docker Compose
#
# Skopiuj ten plik do .env w katalogu głównym projektu:
#   Linux/macOS:  cp .env.example .env
#   Windows:      copy .env.example .env
#
# Plik .env nie trafia do repozytorium. Przed release ustaw JWT_SECRET
# na długi, losowy ciąg znaków (min. 32 znaki).

# Klucz podpisywania tokenów JWT (wymagany w produkcji)
JWT_SECRET=change-me-in-production-use-long-random-string

# Adres API widoczny dla frontendu (wbudowywany przy buildzie obrazu frontend_app)
REACT_APP_API_URL=http://localhost:5000/api

# Dozwolone originy CORS backendu (lista po przecinku, bez spacji)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
