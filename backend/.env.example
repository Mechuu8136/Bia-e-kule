# EnergyCity — konfiguracja backendu (tryb deweloperski)
#
# Skopiuj do backend/.env:
#   Linux/macOS:  cp .env.example .env
#   Windows:      copy .env.example .env
#
# Wymaga uruchomionej bazy: docker compose up -d postgres_db

# PostgreSQL (port 5435 na hoście — mapowanie z docker-compose.yml)
DATABASE_URL=postgres://admin:super_secret_password@localhost:5435/energycity_metrics

# Klucz JWT — musi być identyczny sensie bezpieczeństwa jak w produkcji
JWT_SECRET=change-me-in-development

# Port nasłuchu API
PORT=5000

# Środowisko uruchomieniowe
NODE_ENV=development

# Originy dozwolone przez CORS (frontend dev server)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
